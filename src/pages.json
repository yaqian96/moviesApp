      "path": "pages/login/login",
      "style": {
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/home/home",
      "style": {
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/movies/movies",
      "style": {
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/tv/tv",
      "style": {
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/search/search",
      "style": {
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/detail/detail",
      "style": {
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/play/play",
      "style": {
        "navigationStyle": "custom"
      }
    }
